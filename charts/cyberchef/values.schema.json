{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "title": "cyberchef values",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "replicaCount",
    "image",
    "imagePullSecrets",
    "nameOverride",
    "fullnameOverride",
    "serviceAccount",
    "podAnnotations",
    "podLabels",
    "podSecurityContext",
    "securityContext",
    "strategy",
    "env",
    "extraEnv",
    "containerPort",
    "service",
    "networkPolicy",
    "ingress",
    "httpRoute",
    "resources",
    "livenessProbe",
    "readinessProbe",
    "autoscaling",
    "podDisruptionBudget",
    "tmpVolume",
    "volumes",
    "volumeMounts",
    "extraObjects",
    "nodeSelector",
    "tolerations",
    "affinity",
    "topologySpreadConstraints",
    "config",
    "test"
  ],
  "definitions": {
    "cpuQuantity": {
      "type": "string",
      "pattern": "^([0-9]+m|[0-9]+(\\.[0-9]+)?)$"
    },
    "quantity": {
      "type": "string",
      "pattern": "^([0-9]+(\\.[0-9]+)?)(Ei|Pi|Ti|Gi|Mi|Ki|E|P|T|G|M|K)?$"
    },
    "intOrString": {
      "oneOf": [
        {
          "type": "integer",
          "minimum": 1,
          "maximum": 65535
        },
        {
          "type": "string",
          "minLength": 1
        }
      ]
    },
    "optionalPort": {
      "oneOf": [
        {
          "type": "integer",
          "minimum": 1,
          "maximum": 65535
        },
        {
          "type": "string",
          "enum": [
            ""
          ]
        }
      ]
    },
    "stringMap": {
      "type": "object",
      "additionalProperties": {
        "type": "string"
      }
    },
    "kubernetesObject": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": true
    },
    "probeHeader": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "value"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "value": {
          "type": "string"
        }
      }
    },
    "probe": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "httpGet": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "path",
            "port"
          ],
          "properties": {
            "path": {
              "type": "string",
              "minLength": 1
            },
            "port": {
              "$ref": "#/definitions/intOrString"
            },
            "host": {
              "type": "string"
            },
            "scheme": {
              "type": "string",
              "enum": [
                "HTTP",
                "HTTPS"
              ]
            },
            "httpHeaders": {
              "type": "array",
              "items": {
                "$ref": "#/definitions/probeHeader"
              }
            }
          }
        },
        "exec": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "command"
          ],
          "properties": {
            "command": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        },
        "tcpSocket": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "port"
          ],
          "properties": {
            "port": {
              "$ref": "#/definitions/intOrString"
            },
            "host": {
              "type": "string"
            }
          }
        },
        "grpc": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "port"
          ],
          "properties": {
            "port": {
              "type": "integer",
              "minimum": 1,
              "maximum": 65535
            },
            "service": {
              "type": "string"
            }
          }
        },
        "initialDelaySeconds": {
          "type": "integer",
          "minimum": 0
        },
        "periodSeconds": {
          "type": "integer",
          "minimum": 1
        },
        "timeoutSeconds": {
          "type": "integer",
          "minimum": 1
        },
        "successThreshold": {
          "type": "integer",
          "minimum": 1
        },
        "failureThreshold": {
          "type": "integer",
          "minimum": 1
        },
        "terminationGracePeriodSeconds": {
          "type": "integer",
          "minimum": 1
        }
      },
      "anyOf": [
        {
          "required": [
            "httpGet"
          ]
        },
        {
          "required": [
            "exec"
          ]
        },
        {
          "required": [
            "tcpSocket"
          ]
        },
        {
          "required": [
            "grpc"
          ]
        }
      ]
    },
    "resourceList": {
      "type": "object",
      "additionalProperties": {
        "type": "string"
      },
      "properties": {
        "cpu": {
          "$ref": "#/definitions/cpuQuantity"
        },
        "memory": {
          "$ref": "#/definitions/quantity"
        },
        "ephemeral-storage": {
          "$ref": "#/definitions/quantity"
        }
      }
    },
    "ingressPath": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "path",
        "pathType"
      ],
      "properties": {
        "path": {
          "type": "string",
          "minLength": 1
        },
        "pathType": {
          "type": "string",
          "enum": [
            "Exact",
            "Prefix",
            "ImplementationSpecific"
          ]
        }
      }
    },
    "ingressHost": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "host",
        "paths"
      ],
      "properties": {
        "host": {
          "type": "string",
          "minLength": 1
        },
        "paths": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/definitions/ingressPath"
          }
        }
      }
    },
    "ingressTls": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "hosts"
      ],
      "properties": {
        "hosts": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "secretName": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "httpRouteParentRef": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "name"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "namespace": {
          "type": "string",
          "minLength": 1
        },
        "sectionName": {
          "type": "string",
          "minLength": 1
        },
        "port": {
          "type": "integer",
          "minimum": 1,
          "maximum": 65535
        }
      }
    },
    "httpRouteRule": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "matches"
      ],
      "properties": {
        "matches": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "minProperties": 1,
            "additionalProperties": true
          }
        },
        "filters": {
          "type": "array",
          "items": {
            "type": "object",
            "minProperties": 1,
            "additionalProperties": true
          }
        }
      }
    }
  },
  "properties": {
    "replicaCount": {
      "type": "integer",
      "minimum": 1
    },
    "image": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "repository",
        "pullPolicy",
        "tag",
        "digest"
      ],
      "properties": {
        "repository": {
          "type": "string",
          "minLength": 1
        },
        "pullPolicy": {
          "type": "string",
          "enum": [
            "Always",
            "IfNotPresent",
            "Never"
          ]
        },
        "tag": {
          "type": "string"
        },
        "digest": {
          "type": "string",
          "pattern": "^(|sha256:[a-fA-F0-9]{64})$"
        }
      }
    },
    "imagePullSecrets": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "name"
        ],
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "nameOverride": {
      "type": "string"
    },
    "fullnameOverride": {
      "type": "string"
    },
    "serviceAccount": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "create",
        "automount",
        "annotations",
        "name"
      ],
      "properties": {
        "create": {
          "type": "boolean"
        },
        "automount": {
          "type": "boolean"
        },
        "annotations": {
          "$ref": "#/definitions/stringMap"
        },
        "name": {
          "type": "string"
        }
      }
    },
    "podAnnotations": {
      "$ref": "#/definitions/stringMap"
    },
    "podLabels": {
      "$ref": "#/definitions/stringMap"
    },
    "podSecurityContext": {
      "type": "object",
      "additionalProperties": true
    },
    "securityContext": {
      "type": "object",
      "additionalProperties": true
    },
    "strategy": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "type"
      ],
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "Recreate",
            "RollingUpdate"
          ]
        }
      }
    },
    "env": {
      "$ref": "#/definitions/stringMap"
    },
    "extraEnv": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": [
          "name"
        ],
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1
          },
          "value": {
            "type": "string"
          },
          "valueFrom": {
            "type": "object",
            "additionalProperties": true
          }
        }
      }
    },
    "containerPort": {
      "type": "integer",
      "minimum": 1,
      "maximum": 65535
    },
    "service": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type",
        "annotations",
        "port",
        "targetPort",
        "appProtocol",
        "nodePort",
        "loadBalancerIP",
        "loadBalancerSourceRanges",
        "externalName"
      ],
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "ClusterIP",
            "NodePort",
            "LoadBalancer",
            "ExternalName"
          ]
        },
        "annotations": {
          "$ref": "#/definitions/stringMap"
        },
        "port": {
          "type": "integer",
          "minimum": 1,
          "maximum": 65535
        },
        "targetPort": {
          "$ref": "#/definitions/intOrString"
        },
        "appProtocol": {
          "type": "string"
        },
        "nodePort": {
          "$ref": "#/definitions/optionalPort"
        },
        "loadBalancerIP": {
          "type": "string"
        },
        "loadBalancerSourceRanges": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "externalName": {
          "type": "string"
        }
      }
    },
    "networkPolicy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "enabled",
        "ingressFrom",
        "egress"
      ],
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "ingressFrom": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": true
          }
        },
        "egress": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": true
          }
        }
      }
    },
    "ingress": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "enabled",
        "className",
        "annotations",
        "hosts",
        "tls"
      ],
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "className": {
          "type": "string"
        },
        "annotations": {
          "$ref": "#/definitions/stringMap"
        },
        "hosts": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/definitions/ingressHost"
          }
        },
        "tls": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/ingressTls"
          }
        }
      }
    },
    "httpRoute": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "enabled",
        "annotations",
        "parentRefs",
        "hostnames",
        "rules"
      ],
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "annotations": {
          "$ref": "#/definitions/stringMap"
        },
        "parentRefs": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/definitions/httpRouteParentRef"
          }
        },
        "hostnames": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "rules": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/definitions/httpRouteRule"
          }
        }
      }
    },
    "resources": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "limits": {
          "$ref": "#/definitions/resourceList"
        },
        "requests": {
          "$ref": "#/definitions/resourceList"
        }
      }
    },
    "livenessProbe": {
      "$ref": "#/definitions/probe"
    },
    "readinessProbe": {
      "$ref": "#/definitions/probe"
    },
    "autoscaling": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "enabled",
        "minReplicas",
        "maxReplicas"
      ],
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "minReplicas": {
          "type": "integer",
          "minimum": 1
        },
        "maxReplicas": {
          "type": "integer",
          "minimum": 1
        },
        "targetCPUUtilizationPercentage": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 1,
          "maximum": 100
        },
        "targetMemoryUtilizationPercentage": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 1,
          "maximum": 100
        }
      }
    },
    "podDisruptionBudget": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "enabled",
        "maxUnavailable"
      ],
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "maxUnavailable": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "tmpVolume": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "sizeLimit"
      ],
      "properties": {
        "sizeLimit": {
          "type": "string",
          "pattern": "^(|([0-9]+(\\.[0-9]+)?)(Ei|Pi|Ti|Gi|Mi|Ki|E|P|T|G|M|K)?)$"
        }
      }
    },
    "volumes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "name"
        ],
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1
          }
        },
        "additionalProperties": true
      }
    },
    "volumeMounts": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": [
          "name",
          "mountPath"
        ],
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1
          },
          "mountPath": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "extraObjects": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/kubernetesObject"
      }
    },
    "nodeSelector": {
      "$ref": "#/definitions/stringMap"
    },
    "tolerations": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true
      }
    },
    "affinity": {
      "type": "object",
      "additionalProperties": true
    },
    "topologySpreadConstraints": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true
      }
    },
    "config": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "default_conf",
        "nginx_conf"
      ],
      "properties": {
        "default_conf": {
          "type": "string"
        },
        "nginx_conf": {
          "type": "string"
        }
      }
    },
    "test": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "image",
        "resources"
      ],
      "properties": {
        "image": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "repository",
            "pullPolicy",
            "tag",
            "digest"
          ],
          "properties": {
            "repository": {
              "type": "string",
              "minLength": 1
            },
            "pullPolicy": {
              "type": "string",
              "enum": [
                "Always",
                "IfNotPresent",
                "Never"
              ]
            },
            "tag": {
              "type": "string",
              "minLength": 1
            },
            "digest": {
              "type": "string",
              "pattern": "^(|sha256:[a-fA-F0-9]{64})$"
            }
          }
        },
        "resources": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "limits": {
              "$ref": "#/definitions/resourceList"
            },
            "requests": {
              "$ref": "#/definitions/resourceList"
            }
          }
        }
      }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "service": {
            "properties": {
              "type": {
                "const": "ExternalName"
              }
            },
            "required": [
              "type"
            ]
          }
        }
      },
      "then": {
        "properties": {
          "service": {
            "properties": {
              "externalName": {
                "type": "string",
                "minLength": 1
              }
            },
            "required": [
              "externalName"
            ]
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "autoscaling": {
            "properties": {
              "enabled": {
                "const": true
              }
            },
            "required": [
              "enabled"
            ]
          }
        }
      },
      "then": {
        "properties": {
          "autoscaling": {
            "anyOf": [
              {
                "properties": {
                  "targetCPUUtilizationPercentage": {
                    "type": "integer"
                  }
                },
                "required": [
                  "targetCPUUtilizationPercentage"
                ]
              },
              {
                "properties": {
                  "targetMemoryUtilizationPercentage": {
                    "type": "integer"
                  }
                },
                "required": [
                  "targetMemoryUtilizationPercentage"
                ]
              }
            ]
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "autoscaling": {
            "properties": {
              "enabled": {
                "const": true
              },
              "targetCPUUtilizationPercentage": {
                "type": "integer"
              }
            },
            "required": [
              "enabled",
              "targetCPUUtilizationPercentage"
            ]
          }
        }
      },
      "then": {
        "properties": {
          "resources": {
            "required": [
              "requests"
            ],
            "properties": {
              "requests": {
                "required": [
                  "cpu"
                ]
              }
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "autoscaling": {
            "properties": {
              "enabled": {
                "const": true
              },
              "targetMemoryUtilizationPercentage": {
                "type": "integer"
              }
            },
            "required": [
              "enabled",
              "targetMemoryUtilizationPercentage"
            ]
          }
        }
      },
      "then": {
        "properties": {
          "resources": {
            "required": [
              "requests"
            ],
            "properties": {
              "requests": {
                "required": [
                  "memory"
                ]
              }
            }
          }
        }
      }
    }
  ]
}
