{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",

  "extends": [
    "config:recommended",
    "docker:enableMajor",
    "replacements:k8s-registry-move",
    ":dependencyDashboard",
    ":semanticCommits",
    ":timezone(Europe/Prague)",
    "github>YOUR_GITHUB_USER/YOUR_REPO//.github/renovate/helm.json5",
    "github>YOUR_GITHUB_USER/YOUR_REPO//.github/renovate/labels.json5",
    "github>YOUR_GITHUB_USER/YOUR_REPO//.github/renovate/semantic_commits.json5"
  ],

  "schedule": [
    "* 22-23,0-4 * * 1-5",
    "* * * * 0,6"
  ],

  "lockFileMaintenance": {
    "enabled": true
  },

  "dependencyDashboardTitle": "Renovate Dashboard",
  "suppressNotifications": [
    "prEditedNotification",
    "prIgnoreNotification"
  ],
  "rebaseWhen": "conflicted",
  "minimumReleaseAge": "3 days",

  "labels": [
    "dependencies"
  ],

  "packageRules": [
    {
      "matchUpdateTypes": ["minor", "patch", "digest", "pin", "pinDigest"],
      "matchCurrentVersion": "!/^0/",
      "automerge": true,
      "automergeType": "pr",
      "platformAutomerge": false
    },
    {
      "matchUpdateTypes": ["major"],
      "automerge": false
    },
    {
      "matchManagers": ["github-actions"],
      "groupName": "github-actions"
    },
    {
      "matchManagers": ["helm-requirements", "helmv3"],
      "groupName": "helm dependencies"
    },
    {
      "matchDatasources": ["docker"],
      "minimumReleaseAge": null
    }
  ]
}